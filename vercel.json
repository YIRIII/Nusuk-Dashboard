{
  "buildCommand": "npm ci && npm -w @hadaq/schemas run build && npm -w @hadaq/web run build",
  "outputDirectory": "web/dist",
  "installCommand": "npm ci --workspaces --include-workspace-root",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://141.147.134.176:3001/api/:path*" },
    { "source": "/health", "destination": "http://141.147.134.176:3001/health" },
    { "source": "/((?!api|health).*)", "destination": "/index.html" }
  ]
}
