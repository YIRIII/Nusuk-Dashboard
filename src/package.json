{
  "name": "@hadaq/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false --ignore ../node_modules src/index.ts",
    "start:dev": "tsx src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "import:v1": "tsx src/scripts/import-v1.ts"
  },
  "dependencies": {
    "@hadaq/schemas": "*",
    "@supabase/supabase-js": "^2.45.4",
    "archiver": "^7.0.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "generic-pool": "^3.9.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "puppeteer-core": "^23.1.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.4",
    "@types/express": "^4.17.21",
    "tsx": "^4.16.5"
  }
}
